<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="appli.accueil.MotDePasseOublieController"
      alignment="CENTER"
      spacing="15"
      padding="20">

    <Label text="Mot de passe oublié" style="-fx-font-size: 20px; -fx-font-weight: bold;" />

    <Label text="Entrez votre adresse e-mail :" />
    <TextField fx:id="emailField" promptText="Votre e-mail" prefWidth="250"/>

    <Button text="Envoyer le code"
            onAction="#envoyerCode"
            style="-fx-background-color: #4CAF50; -fx-text-fill: white;" />

</VBox>
